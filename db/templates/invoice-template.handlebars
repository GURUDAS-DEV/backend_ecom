<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Invoice</title>
  <style>
    body {
      font-family: 'Helvetica', sans-serif;
      color: #333;
      line-height: 1.5;
    }
    .container {
      max-width: 210mm;
      margin: 0 auto;
    }
    .header {
      display: flex;
      justify-content: space-between;
      padding: 20px 0;
      border-bottom: 1px solid #eee;
    }
    .logo-section {
      display: flex;
      align-items: center;
    }
    .logo {
      width: 50px;
      height: 50px;
      margin-right: 15px;
    }
    .company-details h1 {
      margin: 0;
      font-size: 18px;
    }
    .company-details p {
      margin: 2px 0;
      font-size: 10px;
    }
    .bank-details {
      font-size: 10px;
    }
    .bank-details h2 {
      font-size: 14px;
      margin-bottom: 5px;
    }
    .title {
      text-align: center;
      font-size: 16px;
      margin: 20px 0;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 20px;
    }
    th, td {
      border: 1px solid #ddd;
      padding: 8px;
      text-align: left;
      font-size: 10px;
    }
    th {
      background-color: #f8f8f8;
      font-weight: bold;
    }
    .text-right {
      text-align: right;
    }
    .summary {
      display: flex;
      justify-content: flex-end;
      margin-bottom: 20px;
    }
    .summary-table {
      width: 300px;
    }
    .summary-table td {
      padding: 5px 8px;
    }
    .footer {
      margin-top: 30px;
      font-size: 10px;
    }
    .footer-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }
    .grand-total {
      font-weight: bold;
      font-size: 14px;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <div class="logo-section">
        <img src= {{logo}} alt="Logo" class="logo">
        <div class="company-details">
          <h1>SHETH TRADING CORPORATION</h1>
          <p>22, RABINDRA SARANI, SHOP NO. 322, GR. FLOOR,</p>
          <p>KOLKATA-700073</p>
          <p>GSTIN: 19AALFS8359M1Z5</p>
          <p>MSME UDYAM REG NO.: WB-10-0039292</p>
          <p>CONTACT: 40240300/22379239</p>
          <p>E-MAIL: shethtrd@gmail.com</p>
        </div>
      </div>
      <div class="bank-details">
        <h2>BANK DETAILS</h2>
        <p>Bank Name: HDFC Bank Ltd.</p>
        <p>Branch: India Exchange Place</p>
        <p>A/c No.: 12422320004133</p>
        <p>IFSC: HDFC0001242</p>
      </div>
    </div>

    <div class="title">
      <h2>Quotation / Proforma Invoice</h2>
      <p>Date: {{currentDate}}</p>
    </div>

    <!-- Item Details -->
    <table>
      <thead>
        <tr>
          <th>Sl.</th>
          <th>Brand</th>
          {{#if hss}}
          <th>Technology</th>
          <th>Type</th>
          <th>Voltage</th>
          <th>Core</th>
          <th>Size</th>
          <th>Cable Type</th>
          <th>Conductor</th>
          {{else}}
          <th>Description</th>
          {{#if includeDiscount}}
          <th>Cable OD (MM)</th>
          <th>Cat No.</th>
          {{/if}}
          {{/if}}
          <th>HSN</th>
          <th>Qty.</th>
          <th>Rate ₹</th>
          {{#if includeDiscount}}
          <th>Discount %</th>
          {{/if}}
          <th>Amount ₹</th>
          <th>Delivery</th>
        </tr>
      </thead>
      <tbody>
        {{#each quotationDetails.items}}
<tr>
  <td>{{add @index 1}}</td>
  <td>{{this.brand}}</td>
  {{#if ../hss}}
    <td>{{this.technology}}</td>
    <td>{{this.type}}</td>
    <td>{{this.voltage}}</td>
    <td>{{this.core}}</td>
    <td>{{this.size}}</td>
    <td>{{this.cableType}}</td>
    <td>{{this.conductor}}</td>
  {{else}}
      {{#if this.description}}
       <td>{{this.description}}</td>
      {{/if}}
  {{/if}}

  {{#if ../includeDiscount}}
    <td>{{this.cableOD}}</td>
    <td>{{this.catNo}}</td>
  {{/if}}

  <td>{{this.hsn}}</td>
  <td>{{this.quantity}}</td>
  <td class="text-right">{{this.rate}}</td>

  {{#if ../includeDiscount}}
    <td class="text-right">{{this.discount}}%</td>
  {{/if}}

  <td class="text-right">
    {{#if ../includeDiscount}}
      {{multiply this.rate this.quantity (subtract 100 this.discount) 0.01}}
    {{else}}
      {{multiply this.rate this.quantity}}
    {{/if}}
  </td>

  <td>{{this.delivery}}</td>
</tr>
{{/each}}

      </tbody>
    </table>

    <!-- Summary -->
    <div class="summary">
      <table class="summary-table">
        <tr>
          <td>Total Amount:</td>
          <td class="text-right">₹ {{totalAmount}}</td>
        </tr>
        <tr>
          <td>GST (18%):</td>
          <td class="text-right">₹ {{gstAmount}}</td>
        </tr>
        <tr class="grand-total">
          <td>Grand Total:</td>
          <td class="text-right">₹ {{grandTotal}}</td>
        </tr>
      </table>
    </div>

    <!-- Payment Terms -->
    <div class="footer">
      <div class="footer-grid">
        <div>
          <h3>Payment Terms:</h3>
          <p>{{payment}}</p>
        </div>
        <div>
          <h3>Validity:</h3>
          <p>{{validity}}</p>
        </div>
      </div>
      
      <!-- Signature -->
      <div style="margin-top: 30px; text-align: right;">
        <p>For SHETH TRADING CORPORATION</p>
        <div style="height: 50px;"></div>
        <p>Authorized Signatory</p>
      </div>
    </div>
  </div>
</body>
</html>