<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Invoice</title>
  <style>
    body {
      font-family: 'Helvetica', sans-serif;
      color: #333;
      line-height: 1.5;
    }
    .container {
      max-width: 210mm;
      margin: 0 auto;
    }
    .header {
      display: flex;
      justify-content: space-between;
      padding: 20px 0;
      border-bottom: 1px solid #eee;
    }
    .logo-section {
      display: flex;
      align-items: center;
    }
    .logo {
      width: 50px;
      height: 50px;
      margin-right: 15px;
    }
    .company-details h1 {
      margin: 0;
      font-size: 18px;
    }
    .company-details p {
      margin: 2px 0;
      font-size: 10px;
    }
    .bank-details {
      font-size: 10px;
    }
    .bank-details h2 {
      font-size: 14px;
      margin-bottom: 5px;
    }
    .title {
      text-align: center;
      font-size: 16px;
      margin: 20px 0;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 20px;
    }
    th, td {
      border: 1px solid #ddd;
      padding: 8px;
      text-align: left;
      font-size: 10px;
    }
    th {
      background-color: #f8f8f8;
      font-weight: bold;
    }
    .text-right {
      text-align: right;
    }
    .summary {
      display: flex;
      justify-content: flex-end;
      margin-bottom: 20px;
    }
    .summary-table {
      width: 300px;
    }
    .summary-table td {
      padding: 5px 8px;
    }
    .footer {
      margin-top: 30px;
      font-size: 10px;
    }
    .footer-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }
    .grand-total {
      font-weight: bold;
      font-size: 14px;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <div class="logo-section">
        <img src="./sheth_logo.jpg" alt="Logo" class="logo">
        <div class="company-details">
          <h1>SHETH TRADING CORPORATION</h1>
          <p>22, RABINDRA SARANI, SHOP NO. 322, GR. FLOOR,</p>
          <p>KOLKATA-700073</p>
          <p>GSTIN: 19AALFS8359M1Z5</p>
          <p>MSME UDYAM REG NO.: WB-10-0039292</p>
          <p>CONTACT: 40240300/22379239</p>
          <p>E-MAIL: shethtrd@gmail.com</p>
        </div>
      </div>
      <div class="bank-details">
        <h2>BANK DETAILS</h2>
        <p>Bank Name: HDFC Bank Ltd.</p>
        <p>Branch: India Exchange Place</p>
        <p>A/c No.: 12422320004133</p>
        <p>IFSC: HDFC0001242</p>
      </div>
    </div>

    <div class="title">
      <h2>Quotation / Proforma Invoice</h2>
    </div>

    <table>
      <thead>
        <tr>
          <th>Sl.</th>
          <th>Description</th>
          <th>Cable OD (MM)</th>
          <th>Cat No.</th>
          <th>HSN</th>
          <th>Qty.</th>
          <th>Rate ₹</th>
          <th>Amount ₹</th>
          <th>Delivery</th>
        </tr>
      </thead>
      <tbody>
        {{#each quotationDetails.items}}
        <tr>
          <td>{{@index}}</td>
          <td>{{this.description}}</td>
          <td>{{this.cableOd}}</td>
          <td>{{this.catNo}}</td>
          <td>85469090</td>
          <td>{{this.quantity}}</td>
          <td class="text-right">₹{{this.rate}}</td>
          <td class="text-right">₹{{multiply this.rate this.quantity}}</td>
          <td>{{this.delivery}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>

    <div class="summary">
      <table class="summary-table">
        <tr>
          <td>Total</td>
          <td class="text-right">₹{{totalAmount}}</td>
        </tr>
        <tr>
          <td>Add: Delivery Charge</td>
          <td class="text-right">₹---</td>
        </tr>
        <tr>
          <td>Add: GST @ 18%</td>
          <td class="text-right">₹{{gstAmount}}</td>
        </tr>
        <tr class="grand-total">
          <td>TOTAL</td>
          <td class="text-right">₹{{grandTotal}}</td>
        </tr>
      </table>
    </div>

    <div class="footer">
      <div class="footer-grid">
        <div>
          <p><strong>Brand:</strong></p>
          <p><strong>GST:</strong> Extra @ 18%</p>
          <p><strong>Payment:</strong> {{payment}}</p>
          <p><strong>Validity:</strong> {{validity}}</p>
        </div>
        <div>
          <p><strong>Delivery:</strong> As Stated Above on Ex godown Kolkata Basis</p>
        </div>
      </div>
    </div>
  </div>
</body>
</html>